# MCQ Battle Platform Log Rotation Configuration
# Save this file to /etc/logrotate.d/mcq-portal
# Set correct permissions: sudo chmod 644 /etc/logrotate.d/mcq-portal

/home/ubuntu/mcq-portal/logs/*.log {
    # Run rotation under the ubuntu user and group to avoid directory security check failures
    su ubuntu ubuntu

    # Rotate logs daily
    daily

    # Keep 14 days of backup logs
    rotate 14

    # Compress rotated files using gzip
    compress

    # Delay compression of the previous log file until the next rotation cycle
    delaycompress

    # Do not write an error if the log file is missing
    missingok

    # Do not rotate the log file if it is empty
    notifempty

    # Create new blank log file with specific user/group and permissions
    create 0640 ubuntu ubuntu

    # Use copytruncate to allow Gunicorn/Flask to write logs without interruption
    copytruncate

    # Run custom commands after rotation completed
    postrotate
        # Log the successful rotation event to system syslog
        logger -t mcq-logrotate "MCQ Platform logs successfully rotated."
    endscript
}
